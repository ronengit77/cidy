{
    "configVersion":  "2026-05-24",
    "purpose":  "Default runtime variables for the split Cidy intent flow: Intent Classifier -\u003e Intent Clarification -\u003e Intent Router.",
    "notes":  [
                  "Use Yes/No strings, not Boolean true/false, because Copilot Studio often treats parsed JSON values as text.",
                  "Only Intent Router should start Formulate Response topics.",
                  "Intent Clarification owns clarification attempts and dead-end handling.",
                  "Default maximum clarification attempts is 2. After that, route to User Feedback."
              ],
    "variables":  {
                      "Global.userQuestion":  {
                                                  "type":  "String",
                                                  "default":  "",
                                                  "ownerTopic":  "Intent Classifier",
                                                  "description":  "Original user question captured before classification."
                                              },
                      "Global.transcript":  {
                                                "type":  "String",
                                                "default":  "",
                                                "ownerTopic":  "User Inquiry / Intent Classifier",
                                                "description":  "Conversation transcript or running context, if used by escalation/user feedback."
                                            },
                      "Global.intentJson":  {
                                                "type":  "String",
                                                "default":  "{}",
                                                "ownerTopic":  "Intent Classifier",
                                                "description":  "Raw JSON returned by the intent classifier."
                                            },
                      "Global.intentReason":  {
                                                  "type":  "String",
                                                  "default":  "",
                                                  "ownerTopic":  "Intent Classifier",
                                                  "description":  "Brief classifier reason for debugging only."
                                              },
                      "Global.intentStatus":  {
                                                  "type":  "String",
                                                  "default":  "needs_classification",
                                                  "allowedValues":  [
                                                                        "needs_classification",
                                                                        "needs_clarification",
                                                                        "ready_to_route",
                                                                        "out_of_scope",
                                                                        "dead_end",
                                                                        "routed"
                                                                    ],
                                                  "ownerTopic":  "Intent Classifier / Intent Clarification / Intent Router",
                                                  "description":  "State variable controlling the flow between the three intent topics."
                                              },
                      "Global.knowledgeDomain":  {
                                                     "type":  "String",
                                                     "default":  "unclear",
                                                     "allowedValues":  [
                                                                           "about_cidy",
                                                                           "da",
                                                                           "rptc",
                                                                           "pdf",
                                                                           "project_evaluation_evidence",
                                                                           "programme_development",
                                                                           "general_cd",
                                                                           "out_of_scope",
                                                                           "unclear"
                                                                       ],
                                                     "ownerTopic":  "Intent Classifier / Intent Clarification",
                                                     "description":  "Primary routing domain. Router uses this before fundingStream."
                                                 },
                      "Global.fundingStream":  {
                                                   "type":  "String",
                                                   "default":  "UNCLEAR",
                                                   "allowedValues":  [
                                                                         "DA",
                                                                         "RPTC",
                                                                         "PDF",
                                                                         "UNCLEAR"
                                                                     ],
                                                   "ownerTopic":  "Intent Classifier / Intent Clarification",
                                                   "description":  "Funding stream when the user explicitly mentions or clarifies it."
                                               },
                      "Global.topicArea":  {
                                               "type":  "String",
                                               "default":  "unclear",
                                               "allowedValues":  [
                                                                     "about_cidy",
                                                                     "budget_finance",
                                                                     "cd_strategy",
                                                                     "definition",
                                                                     "design_evaluation",
                                                                     "evaluation_criteria",
                                                                     "evaluation_design",
                                                                     "evaluation_evidence",
                                                                     "general",
                                                                     "governance_roles",
                                                                     "ipmr",
                                                                     "lessons_learned",
                                                                     "monitoring_reporting",
                                                                     "policy_compliance",
                                                                     "policy_guidance_compliance",
                                                                     "process_governance",
                                                                     "programme_design_standards",
                                                                     "programme_management",
                                                                     "project_planning_design",
                                                                     "projects_evaluations",
                                                                     "recommendations",
                                                                     "reporting_documentation",
                                                                     "reports",
                                                                     "steering_committee",
                                                                     "tag",
                                                                     "tag_meetings",
                                                                     "templates",
                                                                     "unclear"
                                                                 ],
                                               "ownerTopic":  "Intent Classifier / Intent Clarification",
                                               "description":  "Secondary classification used by Formulate Response topics and routing diagnostics."
                                           },
                      "Global.requiresClarification":  {
                                                           "type":  "String",
                                                           "default":  "No",
                                                           "allowedValues":  [
                                                                                 "Yes",
                                                                                 "No"
                                                                             ],
                                                           "ownerTopic":  "Intent Classifier / Intent Clarification",
                                                           "description":  "Whether the next step should ask a clarification question."
                                                       },
                      "Global.clarificationType":  {
                                                       "type":  "String",
                                                       "default":  "none",
                                                       "allowedValues":  [
                                                                             "none",
                                                                             "fund",
                                                                             "domain",
                                                                             "artifact"
                                                                         ],
                                                       "ownerTopic":  "Intent Classifier / Intent Clarification",
                                                       "description":  "Type of clarification needed."
                                                   },
                      "Global.clarificationQuestion":  {
                                                           "type":  "String",
                                                           "default":  "",
                                                           "ownerTopic":  "Intent Classifier / Intent Clarification",
                                                           "description":  "Question text to show to the user when clarification is needed."
                                                       },
                      "Global.clarificationAnswer":  {
                                                         "type":  "String",
                                                         "default":  "",
                                                         "ownerTopic":  "Intent Clarification",
                                                         "description":  "Raw typed or clicked answer from the user."
                                                     },
                      "Global.normalizedClarificationAnswer":  {
                                                                   "type":  "String",
                                                                   "default":  "",
                                                                   "ownerTopic":  "Intent Clarification",
                                                                   "description":  "Controlled normalized value derived from clarificationAnswer."
                                                               },
                      "Global.clarificationAttempts":  {
                                                           "type":  "Number",
                                                           "default":  0,
                                                           "ownerTopic":  "Intent Clarification",
                                                           "description":  "Number of clarification attempts already used for the current user question."
                                                       },
                      "Global.maxClarificationAttempts":  {
                                                              "type":  "Number",
                                                              "default":  2,
                                                              "ownerTopic":  "Intent Classifier / Intent Clarification",
                                                              "description":  "Maximum clarification attempts before moving to User Feedback."
                                                          },
                      "Global.routingTarget":  {
                                                   "type":  "String",
                                                   "default":  "",
                                                   "allowedValues":  [
                                                                         "",
                                                                         "Formulate Response About Cidy",
                                                                         "Formulate Response DA",
                                                                         "Formulate Response RPTC",
                                                                         "Formulate Response PDF",
                                                                         "Formulate Response Project Evaluation Evidence",
                                                                         "Formulate Response Programme Development",
                                                                         "Formulate Response General",
                                                                         "User Feedback"
                                                                     ],
                                                   "ownerTopic":  "Intent Router",
                                                   "description":  "Optional diagnostic variable showing the route selected by the router."
                                               },
                      "Global.draftResponse":  {
                                                   "type":  "String",
                                                   "default":  "",
                                                   "ownerTopic":  "Formulate Response topics / Intent Router for out-of-scope",
                                                   "description":  "Draft answer or controlled out-of-scope/dead-end message."
                                               },
                      "Global.confidenceScore":  {
                                                     "type":  "String",
                                                     "default":  "",
                                                     "ownerTopic":  "Formulate Response / Assess Confidence",
                                                     "description":  "Confidence score returned by a Formulate Response topic."
                                                 },
                      "Global.confidenceLabel":  {
                                                     "type":  "String",
                                                     "default":  "",
                                                     "ownerTopic":  "Assess Confidence / Intent Router",
                                                     "description":  "Human-readable confidence label."
                                                 },
                      "Global.warningMessage":  {
                                                    "type":  "String",
                                                    "default":  "",
                                                    "ownerTopic":  "Intent Router / Apologize-Warn",
                                                    "description":  "Warning message for low-confidence, out-of-scope, or dead-end paths."
                                                },
                      "Global.issueSummary":  {
                                                  "type":  "String",
                                                  "default":  "",
                                                  "ownerTopic":  "Intent Router / User Feedback / Escalate",
                                                  "description":  "Short summary used if the user provides feedback or escalates."
                                              },
                      "Global.userFeedback":  {
                                                  "type":  "String",
                                                  "default":  "",
                                                  "ownerTopic":  "User Feedback",
                                                  "description":  "User satisfaction or feedback response."
                                              },
                      "Global.askAnother":  {
                                                "type":  "String",
                                                "default":  "",
                                                "ownerTopic":  "User Feedback",
                                                "description":  "Whether the user wants to ask another question."
                                            }
                  },
    "initialization":  {
                           "onNewUserQuestion":  {
                                                     "Global.intentJson":  "{}",
                                                     "Global.intentReason":  "",
                                                     "Global.intentStatus":  "needs_classification",
                                                     "Global.knowledgeDomain":  "unclear",
                                                     "Global.fundingStream":  "UNCLEAR",
                                                     "Global.topicArea":  "unclear",
                                                     "Global.requiresClarification":  "No",
                                                     "Global.clarificationType":  "none",
                                                     "Global.clarificationQuestion":  "",
                                                     "Global.clarificationAnswer":  "",
                                                     "Global.normalizedClarificationAnswer":  "",
                                                     "Global.clarificationAttempts":  0,
                                                     "Global.maxClarificationAttempts":  2,
                                                     "Global.routingTarget":  "",
                                                     "Global.draftResponse":  "",
                                                     "Global.confidenceScore":  "",
                                                     "Global.confidenceLabel":  "",
                                                     "Global.warningMessage":  "",
                                                     "Global.issueSummary":  "",
                                                     "Global.userFeedback":  "",
                                                     "Global.askAnother":  ""
                                                 }
                       },
    "statusRules":  {
                        "afterInitialClassification":  [
                                                           {
                                                               "if":  "Global.knowledgeDomain = \u0027out_of_scope\u0027",
                                                               "set":  {
                                                                           "Global.intentStatus":  "out_of_scope",
                                                                           "Global.requiresClarification":  "No"
                                                                       }
                                                           },
                                                           {
                                                               "if":  "Global.requiresClarification = \u0027Yes\u0027",
                                                               "set":  {
                                                                           "Global.intentStatus":  "needs_clarification"
                                                                       }
                                                           },
                                                           {
                                                               "if":  "Global.requiresClarification = \u0027No\u0027 AND Global.knowledgeDomain \u003c\u003e \u0027out_of_scope\u0027",
                                                               "set":  {
                                                                           "Global.intentStatus":  "ready_to_route"
                                                                       }
                                                           }
                                                       ],
                        "afterSuccessfulClarification":  {
                                                             "set":  {
                                                                         "Global.requiresClarification":  "No",
                                                                         "Global.clarificationType":  "none",
                                                                         "Global.clarificationQuestion":  "",
                                                                         "Global.intentStatus":  "ready_to_route"
                                                                     }
                                                         },
                        "afterMaxClarificationAttempts":  {
                                                              "set":  {
                                                                          "Global.intentStatus":  "dead_end",
                                                                          "Global.requiresClarification":  "No",
                                                                          "Global.routingTarget":  "User Feedback",
                                                                          "Global.warningMessage":  "Cidy could not confidently classify the question after two clarification attempts."
                                                                      }
                                                          }
                    },
    "clarificationDefaults":  {
                                  "fund":  {
                                               "question":  "Which funding stream do you mean?",
                                               "choices":  [
                                                               "Development Account (DA)",
                                                               "RPTC",
                                                               "UNPDF / PDF",
                                                               "Not sure"
                                                           ],
                                               "notSureMapsTo":  {
                                                                     "Global.knowledgeDomain":  "general_cd",
                                                                     "Global.fundingStream":  "UNCLEAR"
                                                                 }
                                           },
                                  "domain":  {
                                                 "question":  "Which area should Cidy use for this question?",
                                                 "choices":  [
