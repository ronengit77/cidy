                                                                       "Global.fundingStream":  "UNCLEAR"
                                                                   }
                                             },
                                  "artifact":  {
                                                   "question":  "Which document type do you mean?",
                                                   "choices":  [
                                                                   "Concept note",
                                                                   "Project document",
                                                                   "Progress report",
                                                                   "Evaluation report",
                                                                   "Management response",
                                                                   "Budget template",
                                                                   "Not sure"
                                                               ],
                                                   "notSureMapsTo":  {
